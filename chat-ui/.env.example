# ============================================================================
# Sovereign Chat Experience — .env for the Foundry Local quickstart
# ----------------------------------------------------------------------------
# Copy this file into your cloned sovereign-chat-experience-starter repo:
#
#   cp ../foundry-local-chat-quickstart/chat-ui/.env.example .env
#
# This selects the chat UI's "completions" mode, which calls /v1/chat/completions
# directly from the browser. No Express server is needed for this quickstart.
#
# For the full set of options the chat UI supports (server mode, mock provider,
# auth, etc.), see the chat UI's own .env.example.
# ============================================================================

# Talk to an OpenAI-compatible /v1/chat/completions endpoint directly.
VITE_API_MODE=completions

# The endpoint the chat UI's browser code talks to. In this quickstart
# that's the small proxy backend at `chat-ui/cors-proxy/`, which listens
# on http://localhost:5001 and forwards to the `kubectl port-forward` on
# http://localhost:5000. The proxy answers CORS preflights itself so the
# browser can complete the round-trip; the user's API key flows through
# unchanged. See Step 7a of the quickstart README, and
# `chat-ui/cors-proxy/README.md` for what the proxy does and why.
#
# In a real-world deployment you would replace the proxy with your own
# backend (handling auth, rate limiting, logging, etc.) and point
# VITE_API_URL at that backend instead.
#
# Variable name follows upstream chat UI convention (see the upstream
# .env.example under "Completions Mode") — it is VITE_API_URL, not
# VITE_COMPLETIONS_URL, even though all the other completions-mode vars
# are prefixed VITE_COMPLETIONS_*.
VITE_API_URL=http://localhost:5001/v1

# Model identifier — must match `data[0].id` from
# `curl -s http://localhost:5000/v1/models`. Defaults to the value the operator
# templates for the default ministral-3-3b.yaml manifest. Update this when you
# swap to a different model (every deployment reports its own model id).
VITE_COMPLETIONS_MODEL=ministral-3-3b-instruct-2512

# Required: the Foundry Local operator enables per-deployment API-key auth by
# default. Fill this from the operator-managed secret:
#
#   kubectl get secret ministral-3-3b-api-keys \
#     -n foundry-local-operator \
#     -o jsonpath='{.data.primary-key}' | base64 -d
#
# Update this when you swap models — each deployment has its own key pair under
# <deployment-name>-api-keys.
VITE_COMPLETIONS_API_KEY=

# Optional: persist conversation history in localStorage across page refreshes
# (upstream variable name; we explicitly opt in here for a nicer demo UX).
VITE_COMPLETIONS_PERSIST_HISTORY=true
